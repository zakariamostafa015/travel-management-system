# Copy this file to .env and edit the values before running Docker Compose.
# The .env file is ignored by git and is the local secret/config file Docker Compose reads.

ASPNETCORE_ENVIRONMENT=Development
API_HTTP_PORT=8080

DATABASE_MIGRATE_ON_STARTUP=true
DATABASE_SEED_ON_STARTUP=true
DATABASE_RECREATE_WHEN_SCHEMA_MISSING=true

SQL_DATABASE=TravelToursWebsite
SQL_PORT=1433
SQL_EDITION=Developer
SQL_SA_PASSWORD=Change_this_SQL_password_123!

JWT_ISSUER=TravelToursWebsite.Api
JWT_AUDIENCE=TravelToursWebsite.Clients
JWT_SECRET=Change_this_to_a_long_random_secret_at_least_32_bytes
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@traveltours.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_UPDATE_PASSWORD=false

SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

CORS_ALLOWED_ORIGIN_0=http://localhost:3000
CORS_ALLOWED_ORIGIN_1=http://localhost:4200
CORS_ALLOWED_ORIGIN_2=http://localhost:5173
