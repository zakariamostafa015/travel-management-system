{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "TravelToursWebsite.Api",
    "Audience": "TravelToursWebsite.Clients",
    "Secret": "",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7
  },
  "Media": {
    "MaxFileSizeBytes": 10485760,
    "MaxWidth": 1920,
    "MaxHeight": 1080,
    "WebPQuality": 82,
    "ThumbnailWidth": 300,
    "ThumbnailHeight": 200,
    "MediumWidth": 800,
    "MediumHeight": 600,
    "UploadRootFolder": "uploads",
    "PublicBasePath": "/uploads"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "AllowedHosts": "*"
}