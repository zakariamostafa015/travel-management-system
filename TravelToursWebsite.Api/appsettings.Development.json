{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=TravelToursWebsite;Trusted_Connection=True;MultipleActiveResultSets=true;Encrypt=False"
  },
  "Jwt": {
    "Issuer": "TravelToursWebsite.Api",
    "Audience": "TravelToursWebsite.Clients",
    "Secret": "DevelopmentOnlyJwtSigningKey-ChangeBeforeProduction-2026",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7
  },
  "Media": {
